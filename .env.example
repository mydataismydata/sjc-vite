# SJC-Vite configuration
# Copy this file to `.env` and adjust. Every value has a sensible default;
# for production you MUST set BASE_URL (links in emails are built from it).

# Port the server listens on.
#PORT=3000

# Public URL of this installation, no trailing slash. Used to build the
# links embedded in invitation emails (Accept / Decline / event page).
#BASE_URL=https://invites.example.org

# Where databases and uploads live. Relative paths resolve from the repo root.
# Back this directory up — it is the entire state of the application.
#DATA_DIR=./data

# SMTP2GO API key (starts with "api-"). Create one at smtp2go.com under
# Settings -> API Keys. When unset, the app runs in SIMULATION mode: emails
# are rendered and logged (viewable in the UI) but nothing is delivered.
# Can also be set per-organization in the web UI (Settings -> Sending),
# which overrides this value.
#SMTP2GO_API_KEY=api-XXXXXXXXXXXXXXXX

# Outbound throttle for the email queue.
#EMAILS_PER_MINUTE=60

# Session lifetime in days.
#SESSION_DAYS=14

# Secret used to sign session cookies. If unset, a random secret is
# generated on first start and persisted to DATA_DIR/secret.key.
#SESSION_SECRET=

# Set to 1 when running behind a reverse proxy (Caddy/nginx) so client IPs
# are read from X-Forwarded-For for rate limiting.
#TRUST_PROXY=1

# Set to "production" on your server (enables Secure cookies when BASE_URL
# is https).
#NODE_ENV=production
